{
  "name": "@adaptivejs/auth",
  "version": "0.1.3",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/build-package.mjs plugins/adaptive-auth && tsc -p tsconfig.json --emitDeclarationOnly",
    "dev": "node ../../scripts/build-package.mjs plugins/adaptive-auth",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@adaptivejs/ft": "^0.1.3",
    "@adaptivejs/ssr": "^0.1.3"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.8.2"
  }
}
