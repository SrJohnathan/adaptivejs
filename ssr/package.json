{
  "name": "@adaptivejs/ssr",
  "version": "0.1.8",
  "description": "Adaptive SSR compatibility layer used by @adaptivejs/web.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../scripts/build-package.mjs ssr && tsc -p tsconfig.json --emitDeclarationOnly",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@adaptivejs/ft": "^0.1.8",
    "express": "^5.1.0",
    "fast-glob": "^3.3.3",
    "formidable": "^3.5.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/formidable": "^3.4.6",
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.2"
  }
}
