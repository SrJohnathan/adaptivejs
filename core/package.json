{
  "name": "@adaptivejs/core",
  "version": "0.1.8",
  "description": "Core contracts, JSX runtime, and IR primitives for Adaptive.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-dev-runtime.d.ts",
      "import": "./dist/jsx-dev-runtime.js"
    }
  },
  "scripts": {
    "build": "node ../scripts/build-package.mjs core && tsc -p tsconfig.json --emitDeclarationOnly",
    "dev": "node ../scripts/build-package.mjs core",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@adaptivejs/ft": "^0.1.8"
  },
  "devDependencies": {
    "typescript": "^5.8.2"
  }
}
